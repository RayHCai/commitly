generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  githubId          Int      @unique
  username          String   @unique
  email             String?
  avatarUrl         String?
  githubAccessToken String
  linkedinUrl       String?
  resumeS3Key       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  repositories     Repository[]
  customLinks      CustomLink[]
  analysisRequests AnalysisRequest[]

  @@map("users")
}

model Repository {
  id           String   @id @default(cuid())
  userId       String
  githubRepoId Int
  name         String
  fullName     String
  url          String
  isPrivate      Boolean   @default(false)
  lastIngestedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, githubRepoId])
  @@index([userId])
  @@map("repositories")
}

enum LinkStatus {
  PENDING
  ACTIVE
  FAILED
}

enum LinkType {
  JOB
  GENERAL
}

model CustomLink {
  id        String     @id @default(cuid())
  userId    String
  slug      String
  title     String?
  targetUrl String?
  jobUrl    String?
  type      LinkType   @default(JOB)
  status    LinkStatus @default(PENDING)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  views        LinkView[]
  requirements Requirement[]

  @@unique([userId, slug])
  @@index([userId])
  @@map("custom_links")
}

model Requirement {
  id           String          @id @default(cuid())
  customLinkId String
  name         String
  description  String
  createdAt    DateTime        @default(now())

  customLink     CustomLink      @relation(fields: [customLinkId], references: [id], onDelete: Cascade)
  matchedCommits MatchedCommit[]

  @@index([customLinkId])
  @@map("requirements")
}

model MatchedCommit {
  id            String   @id @default(cuid())
  requirementId String
  commitSha     String
  repoName      String
  url           String
  message       String
  diff          String   @db.Text
  tags          String[] @default([])
  score         Float
  summary       String   @default("")
  createdAt     DateTime @default(now())

  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@index([requirementId])
  @@map("matched_commits")
}

model LinkView {
  id           String   @id @default(cuid())
  customLinkId String
  ipAddress    String?
  userAgent    String?
  referrer     String?
  viewedAt     DateTime @default(now())

  customLink CustomLink @relation(fields: [customLinkId], references: [id], onDelete: Cascade)

  @@index([customLinkId])
  @@index([viewedAt])
  @@index([customLinkId, viewedAt])
  @@map("link_views")
}

model AnalysisRequest {
  id        String         @id @default(cuid())
  userId    String
  status    AnalysisStatus @default(PENDING)
  payload   Json?
  result    Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@map("analysis_requests")
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model PendingJobUrl {
  id        String   @id @default(cuid())
  sessionId String
  jobUrl    String
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("pending_job_urls")
}
