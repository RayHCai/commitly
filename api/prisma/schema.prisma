generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  githubId          Int      @unique
  username          String   @unique
  email             String?
  avatarUrl         String?
  githubAccessToken String
  linkedinUrl       String?
  resumeS3Key       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  repositories     Repository[]
  customLinks      CustomLink[]
  analysisRequests AnalysisRequest[]

  @@map("users")
}

model Repository {
  id           String   @id @default(cuid())
  userId       String
  githubRepoId Int
  name         String
  fullName     String
  url          String
  isPrivate      Boolean   @default(false)
  lastIngestedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commits Commit[]

  @@unique([userId, githubRepoId])
  @@index([userId])
  @@map("repositories")
}

model Commit {
  id           String   @id @default(cuid())
  repositoryId String
  sha          String
  message      String
  authorName   String
  authorEmail  String?
  committedAt  DateTime
  diffSummary  String?
  complexity   Float?
  tags         String[]
  createdAt    DateTime @default(now())

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, sha])
  @@index([repositoryId])
  @@map("commits")
}

enum LinkStatus {
  PENDING
  ACTIVE
  FAILED
}

model CustomLink {
  id        String     @id @default(cuid())
  userId    String
  slug      String
  title     String?
  targetUrl String?
  jobUrl    String?
  status    LinkStatus @default(PENDING)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  views LinkView[]

  @@unique([userId, slug])
  @@index([userId])
  @@map("custom_links")
}

model LinkView {
  id           String   @id @default(cuid())
  customLinkId String
  ipAddress    String?
  userAgent    String?
  referrer     String?
  viewedAt     DateTime @default(now())

  customLink CustomLink @relation(fields: [customLinkId], references: [id], onDelete: Cascade)

  @@index([customLinkId])
  @@index([viewedAt])
  @@index([customLinkId, viewedAt])
  @@map("link_views")
}

model AnalysisRequest {
  id        String         @id @default(cuid())
  userId    String
  status    AnalysisStatus @default(PENDING)
  payload   Json?
  result    Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@map("analysis_requests")
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model PendingJobUrl {
  id        String   @id @default(cuid())
  sessionId String
  jobUrl    String
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("pending_job_urls")
}
